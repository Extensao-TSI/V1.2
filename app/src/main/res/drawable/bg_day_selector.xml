<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selecionado: fundo azul e letra branca -->
    <item android:state_checked="true">
        <shape android:shape="oval">
            <solid android:color="#1565C0" />
            <stroke
                android:width="2dp"
                android:color="#1565C0" />
            <size
                android:width="44dp"
                android:height="44dp" />
        </shape>
    </item>

    <!-- Não selecionado: fundo branco e borda azul clara -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="2dp"
                android:color="#801565C0" />
            <size
                android:width="44dp"
                android:height="44dp" />
        </shape>
    </item>

</selector>

