<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/logoBackground2"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:alpha="0.8"
        android:scaleType="centerInside"
        android:src="@drawable/ifms2" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/textViewTituloAdicionar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:shadowColor="#0D47A1"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="Adicionar Horário"
                android:textSize="24sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorarioInicial"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Selecionar Horário Inicial" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorarioFinal"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Selecionar Horário Final" />

            <!-- Seletor de dias da semana -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Dias da semana"
                android:textColor="#0D47A1"
                android:textSize="20dp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbDom"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Domingo" />

                    <CheckBox
                        android:id="@+id/cbSeg"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Segunda" />

                    <CheckBox
                        android:id="@+id/cbTer"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Terça" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbQua"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quarta" />

                    <CheckBox
                        android:id="@+id/cbQui"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Quinta" />

                    <CheckBox
                        android:id="@+id/cbSex"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Sexta" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbSab"
                        style="@style/Days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sábado" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarHorario"
                style="@style/AppButtonLigar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salvar Horário" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
