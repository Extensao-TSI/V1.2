<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@drawable/gradient_background"
	android:padding="16dp">

	<com.google.android.material.card.MaterialCardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="16dp"
		app:cardCornerRadius="20dp"
		app:cardElevation="8dp"
		app:cardBackgroundColor="#4A90E2">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="20dp">

			<TextView
				android:id="@+id/textViewTituloLista"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Lista de Horários"
				android:textSize="24sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_marginBottom="20dp"
				android:gravity="center"
				android:shadowColor="#000000"
				android:shadowDx="2"
				android:shadowDy="2"
				android:shadowRadius="4"/>

			<com.google.android.material.button.MaterialButton
				android:id="@+id/btnAdicionarHorario"
				style="@style/AppButtonSecondary"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Adicionar Novo Horário"
				android:layout_marginBottom="16dp"/>

			<TextView
				android:id="@+id/textViewSemHorariosCadastrados"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Nenhum horário cadastrado"
				android:textSize="16sp"
				android:textColor="#E3F2FD"
				android:gravity="center"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:layout_marginBottom="16dp"/>

		</LinearLayout>
	</com.google.android.material.card.MaterialCardView>

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/recyclerViewHorarios"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"/>

</LinearLayout>